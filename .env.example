# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── MS SQL Server ─────────────────────────────────────────────────────────────
# Example: "DRIVER={ODBC Driver 18 for SQL Server};SERVER=server;DATABASE=CWESystemConfig;UID=user;PWD=pass;TrustServerCertificate=yes"
MSSQL_CONN_STR=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API Keys
SUPABASE_URL=https://your-project-ref.supabase.co
# SECRET key (sb_secret_...) — server-side only, used by Python backend to validate JWTs
SUPABASE_SECRET_KEY=sb_secret_your_key_here
# PUBLISHABLE key (sb_publishable_...) — safe for browser, used in the login page JS
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ── Auth settings ─────────────────────────────────────────────────────────────
# Set to "true" to require users to pass 2FA (MFA AAL2) before accessing FundPilot
REQUIRE_MFA=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development:  ALLOWED_ORIGINS=http://localhost:3000
# Production:   ALLOWED_ORIGINS=https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Development:  CHROMADB_PERSIST_DIR=./chromadb_data
# Production:   CHROMADB_PERSIST_DIR=C:\FundPilot\chromadb_data
CHROMADB_PERSIST_DIR=./chromadb_data
