# FundPilot reverse proxy configuration
# Replace "yourdomain.com" with your actual domain before deploying.
#
# Caddy automatically obtains and renews a TLS certificate from Let's Encrypt.
# Requirement: port 80 and 443 must be reachable from the internet for ACME challenges.

yourdomain.com {

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "SAMEORIGIN"
        Referrer-Policy           "strict-origin-when-cross-origin"
        # Remove server fingerprint
        -Server
    }

    # Proxy everything to FastAPI (Uvicorn on localhost)
    reverse_proxy 127.0.0.1:8000 {
        # Forward real client IP to the app
        header_up X-Real-IP        {remote_host}
        header_up X-Forwarded-For  {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Access log
    log {
        output file C:\Caddy\logs\access.log {
            roll_size     50mb
            roll_keep     5
        }
    }
}
